# SocTrack Environment Variables

# Database
DATABASE_URL=postgresql://soctrack:your_password@localhost:5432/soctrack

# App
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=production
SECRET_KEY=change-this-to-a-random-secret-key

# Business (default untuk fase awal single-tenant)
DEFAULT_BUSINESS_NAME=Army Group

# Scraper
SCRAPE_DELAY_MIN=30
SCRAPE_DELAY_MAX=90
SCRAPE_BATCH_SIZE=50
SCRAPE_START_HOUR=0
SCRAPE_MAX_POSTS_PER_CYCLE=350

# Proxy (opsional - uncomment jika VPS IP diblock)
# PROXY_URL=http://user:pass@proxy.example.com:port
# PROXY_ENABLED=true

# Timezone
TZ=Asia/Jakarta
